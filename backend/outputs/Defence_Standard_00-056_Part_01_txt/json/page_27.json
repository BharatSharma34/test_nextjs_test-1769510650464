{
  "graph_intent": "section_retrieval",
  "document_name": "DEF STAN 00-056 Part 01 Issue 8",
  "nodes": [
    {
      "id": "INSA:9.10",
      "number": "9.10",
      "title": "Satisfaction of Requirements",
      "kind": "section",
      "appears_on_pages": [
        27
      ],
      "primary_page": 27
    },
    {
      "id": "INSA:9.10.1",
      "number": "9.10.1",
      "title": "The contractor shall carry out safety and systems engineering activities to provide evidence that all safety requirements, including derived safety requirements, have been met.",
      "kind": "subsection",
      "appears_on_pages": [
        27
      ],
      "primary_page": 27
    },
    {
      "id": "INSA:9.10.2",
      "number": "9.10.2",
      "title": "The contractor shall undertake systems engineering activities which are capable of detecting counter-evidence.",
      "kind": "subsection",
      "appears_on_pages": [
        27
      ],
      "primary_page": 27
    },
    {
      "id": "INSA:9.10.3",
      "number": "9.10.3",
      "title": "The contractor shall identify the most effective method, or methods, for showing satisfaction of requirements, or providing counter-evidence, and include this information in the SMP.",
      "kind": "subsection",
      "appears_on_pages": [
        27
      ],
      "primary_page": 27
    },
    {
      "id": "INSA:9.10.4",
      "number": "9.10.4",
      "title": "Whilst there might be general identification of techniques early in the process, the contractor shall ensure that the methods chosen are appropriate to the specific derived safety requirements identified.",
      "kind": "subsection",
      "appears_on_pages": [
        27
      ],
      "primary_page": 27
    },
    {
      "id": "INSA:10",
      "number": "10",
      "title": "Safety Reporting",
      "kind": "section",
      "appears_on_pages": [
        27
      ],
      "primary_page": 27
    },
    {
      "id": "INSA:10.1",
      "number": "10.1",
      "title": "Information Set Safety Summary",
      "kind": "subsection",
      "appears_on_pages": [
        27
      ],
      "primary_page": 27
    },
    {
      "id": "INSA:10.1.1",
      "number": "10.1.1",
      "title": "The contractor shall produce an ISSS as defined in the SMP.",
      "kind": "subsection",
      "appears_on_pages": [
        27
      ],
      "primary_page": 27
    },
    {
      "id": "INSA:10.1.2",
      "number": "10.1.2",
      "title": "The contractor shall ensure that the ISSS contains sufficient information from the information set to enable a system integrator and a system operator to discharge their safety responsibilities.",
      "kind": "subsection",
      "appears_on_pages": [
        27
      ],
      "primary_page": 27
    },
    {
      "id": "INSA:10.1.3",
      "number": "10.1.3",
      "title": "The contractor shall ensure that the ISSS contains information on assumptions and limitations regarding the safe use of the PSS.",
      "kind": "subsection",
      "appears_on_pages": [
        27
      ],
      "primary_page": 27
    },
    {
      "id": "INSA:10.1.4",
      "number": "10.1.4",
      "title": "The contractor shall ensure that the ISSS includes a justification of the scope of the information provided.",
      "kind": "subsection",
      "appears_on_pages": [
        27
      ],
      "primary_page": 27
    },
    {
      "id": "INSA:10.1.5",
      "number": "10.1.5",
      "title": "The contractor shall ensure that the ISSS is delivered incrementally, as contracted and as defined in the SMP, to give the UK MOD visibility of progress in safety engineering and safety analysis.",
      "kind": "subsection",
      "appears_on_pages": [
        27
      ],
      "primary_page": 27
    },
    {
      "id": "INSA:10.2",
      "number": "10.2",
      "title": "Safety Case",
      "kind": "subsection",
      "appears_on_pages": [
        27
      ],
      "primary_page": 27
    },
    {
      "id": "INSA:10.2.1",
      "number": "10.2.1",
      "title": "The contractor shall produce a safety case or safety cases for a PSS as defined in the SMP.",
      "kind": "subsection",
      "appears_on_pages": [
        27
      ],
      "primary_page": 27
    },
    {
      "id": "INSA:10.2.2",
      "number": "10.2.2",
      "title": "The contractor shall ensure that the safety case consists of a structured argument, supported by a body of evidence that provides a compelling, comprehensible and valid case that a system is safe for a given application in a given environment.",
      "kind": "subsection",
      "appears_on_pages": [
        27
      ],
      "primary_page": 27
    },
    {
      "id": "INSA:10.2.3",
      "number": "10.2.3",
      "title": "The contractor shall ensure that the evidence for the safety case is drawn from the information set.",
      "kind": "subsection",
      "appears_on_pages": [
        27
      ],
      "primary_page": 27
    },
    {
      "id": "INSA:10.2.4",
      "number": "10.2.4",
      "title": "The contractor shall address safety throughout the life of the PSS within the safety case, to the extent required by the scope of contract.",
      "kind": "subsection",
      "appears_on_pages": [
        27
      ],
      "primary_page": 27
    },
    {
      "id": "INSA:10.2.5",
      "number": "10.2.5",
      "title": "The contractor shall provide evidence that supports claims for the verification and validation of all safety requirements, including evidence from sub-contractors.",
      "kind": "subsection",
      "appears_on_pages": [
        27
      ],
      "primary_page": 27
    }
  ],
